<svg xmlns="http://www.w3.org/2000/svg" width="1440" height="720" viewBox="0 0 1440 720">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#EDE5CC"/>
      <stop offset="50%" stop-color="#FAF5E8"/>
      <stop offset="100%" stop-color="#D4921A" stop-opacity="0.15"/>
    </linearGradient>
    <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
      <path d="M30 0 L60 30 L30 60 L0 30 Z" fill="none" stroke="#1A4A3A" stroke-width="0.4" opacity="0.12"/>
    </pattern>
  </defs>
  <rect width="1440" height="720" fill="url(#bg)"/>
  <rect width="1440" height="720" fill="url(#grid)"/>
  <text x="720" y="330" font-family="Georgia, serif" font-size="28" fill="#1A4A3A" text-anchor="middle" opacity="0.4" font-style="italic">Hero Banner</text>
  <text x="720" y="370" font-family="Georgia, serif" font-size="18" fill="#1A4A3A" text-anchor="middle" opacity="0.3">Wide-angle interior shot of dining room — 1440 × 720px</text>
  <text x="720" y="405" font-family="Georgia, serif" font-size="14" fill="#B5231A" text-anchor="middle" opacity="0.3">Replace with real photo</text>
</svg>
