<svg xmlns="http://www.w3.org/2000/svg" width="600" height="600" viewBox="0 0 600 600">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#EDE5CC"/>
      <stop offset="100%" stop-color="#D4921A" stop-opacity="0.12"/>
    </linearGradient>
  </defs>
  <rect width="600" height="600" fill="url(#bg)"/>
  <text x="300" y="280" font-family="Georgia, serif" font-size="18" fill="#1A4A3A" text-anchor="middle" opacity="0.4" font-style="italic">Thai Tom Yum Pho</text>
  <text x="300" y="315" font-family="Georgia, serif" font-size="13" fill="#1A4A3A" text-anchor="middle" opacity="0.3">Overhead shot — 600 × 600px</text>
</svg>
